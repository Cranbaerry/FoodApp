# ---- OpenAI (Vercel AI SDK) ----
OPENAI_API_KEY=sk-...

# ---- Model / conversation tuning (all optional, shown with defaults) ----
CHAT_MODEL=gpt-4o
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1024
# Override the assistant's persona / behaviour entirely:
# SYSTEM_PROMPT="You are a warm, knowledgeable food companion..."

# ---- Supabase (server-side; service-role bypasses RLS) ----
NEXT_PUBLIC_SUPABASE_URL=https://nblmkcupnxtyyymbgjhv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # Dashboard → Project Settings → API → service_role key

# ---- scripts/analyze-commits (npm run analyze) ----
# Required by `npm run analyze` for measured coding time.
# Get it from https://wakatime.com/settings/api-key
WAKATIME_API_KEY=
# Optional overrides:
# ANALYZE_DAYS=7
# ANALYZE_AUTHOR=you@example.com
# WakaTime hours are scoped to this repo's folder name by default.
# Override the WakaTime project name, or set empty to count ALL projects:
# ANALYZE_PROJECT=FoodApp
